# =============================================================================
# MCDSS Environment Variables
# Copy this file to .env and fill in your values:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL  (local installation — not containerized)
# Containers connect to this via host.docker.internal
# -----------------------------------------------------------------------------
DB_PORT=5432
DB_DATABASE=faculty_mcdss
DB_USERNAME=postgres
DB_PASSWORD=mcdss_password

# -----------------------------------------------------------------------------
# Laravel
# -----------------------------------------------------------------------------
APP_ENV=local
APP_DEBUG=true
# Generate with: docker compose exec laravel php artisan key:generate --show
APP_KEY=

# Email address that appears in the From field of outgoing emails
MAIL_FROM_ADDRESS=noreply@mcdss.local

# -----------------------------------------------------------------------------
# Next.js Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# -----------------------------------------------------------------------------
# FastAPI internal auth
# Laravel sends this header to FastAPI on every internal request.
# Change to a strong random string in production.
# -----------------------------------------------------------------------------
FASTAPI_SECRET_KEY=changeme
